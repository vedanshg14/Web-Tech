rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == "admin";
    }
    
    // Users collection and nested rides
    match /users/{userId}/rides/{rideId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // Base user profile document
    match /users/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // User profiles collection - Added to fix permission issues
    match /userProfiles/{userId} {
      allow read, write: if request.auth != null && 
        (request.auth.uid == userId || isAdmin());
    }
    
    // Admin collection
    match /admins/{adminId} {
      allow read: if request.auth != null && request.auth.uid == adminId;
    }
    
    match /blogs/{blogId} {
      // Allow admin users full access
      allow create, update, delete: if isAdmin();
      
      // Allow reading of all blog posts for everyone
      // If you want to restrict reading to only published blogs for non-admins, use:
      // allow read: if resource.data.status == "published" || isAdmin();
      allow read: if true;
    }
    
    // Communities collection
    match /communities/{communityId} {
      // Allow read for all authenticated users
      allow read: if request.auth != null;
      
      // Allow write if user is a moderator or admin
      allow write: if request.auth != null && 
        (request.auth.uid in resource.data.moderators || isAdmin());
      
      // Allow create if user is setting themselves as creator and moderator
      allow create: if request.auth != null && 
        request.auth.uid == request.resource.data.createdBy &&
        request.auth.uid in request.resource.data.moderators;
    }
    
    // Eats Orders collection - Allow anyone to create orders
    match /eatsOrders/{orderId} {
      // Allow anyone to create orders without authentication
      allow create: if true;
      
      // Only admins can read, update or delete orders
      allow read, update, delete: if isAdmin();
    }
    
    // Bikes Orders collection - Allow anyone to create orders
    match /bikesOrders/{orderId} {
      // Allow anyone to create orders without authentication
      allow create: if true;
      
      // Only admins can read, update or delete orders
      allow read, update, delete: if isAdmin();
    }
  }
}